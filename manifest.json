{
  "manifest_version": 3,
  "name": "BiliArm",
  "version": "0.0.1",
  "description": "整合 B 站推荐净化、黑名单、播放器快捷键、截图、反追踪和页面样式优化的浏览器扩展。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://api.bilibili.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "BiliArm",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/logo_example.png",
      "32": "assets/logo_example.png",
      "48": "assets/logo_example.png",
      "128": "assets/logo_example.png"
    }
  },
  "icons": {
    "16": "assets/logo_example.png",
    "32": "assets/logo_example.png",
    "48": "assets/logo_example.png",
    "128": "assets/logo_example.png"
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/page/page-agent.js"
      ],
      "matches": [
        "https://www.bilibili.com/*",
        "https://search.bilibili.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/*",
        "https://search.bilibili.com/*"
      ],
      "js": [
        "src/common/config.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
